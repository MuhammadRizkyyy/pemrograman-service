          "name": "Register Buyer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.success && res.data && res.data.accessToken) {",
                  "    pm.collectionVariables.set(\"token\", res.data.accessToken);",
                  "    pm.collectionVariables.set(\"refresh_token\", res.data.refreshToken);",
                  "}"
