{
  "info": {
    "name": "Iris ML Microservice",
    "_postman_id": "iris-ml-microservice-collection",
    "description": "Koleksi API untuk sistem microservice Iris ML dengan FastAPI + Express.js",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "ml_url", "value": "http://localhost:3091", "type": "string" },
    { "key": "express_url", "value": "http://localhost:3092", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Python ML Service (FastAPI)",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{ml_url}}/health",
            "description": "Cek status ML service, model, dan Redis"
          }
        },
        {
          "name": "Login - Get JWT Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "  console.log('Token saved!');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{ml_url}}/auth/token",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "user" },
                { "key": "password", "value": "user123" }
              ]
            },
            "description": "Login dan dapatkan JWT token. Token otomatis disimpan ke variable."
          }
        },
        {
          "name": "Predict - Iris Setosa",
          "request": {
            "method": "POST",
            "url": "{{ml_url}}/predict",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sepal_length\": 5.1,\n  \"sepal_width\": 3.5,\n  \"petal_length\": 1.4,\n  \"petal_width\": 0.2\n}"
            },
            "description": "Prediksi bunga Iris (contoh: Iris-setosa)"
          }
        },
        {
          "name": "Predict - Iris Virginica",
          "request": {
            "method": "POST",
            "url": "{{ml_url}}/predict",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sepal_length\": 6.3,\n  \"sepal_width\": 3.3,\n  \"petal_length\": 6.0,\n  \"petal_width\": 2.5\n}"
            }
          }
        },
        {
          "name": "Batch Predict",
          "request": {
            "method": "POST",
            "url": "{{ml_url}}/batch-predict",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": [\n    { \"sepal_length\": 5.1, \"sepal_width\": 3.5, \"petal_length\": 1.4, \"petal_width\": 0.2 },\n    { \"sepal_length\": 7.0, \"sepal_width\": 3.2, \"petal_length\": 4.7, \"petal_width\": 1.4 },\n    { \"sepal_length\": 6.3, \"sepal_width\": 3.3, \"petal_length\": 6.0, \"petal_width\": 2.5 }\n  ]\n}"
            },
            "description": "Prediksi batch untuk 3 bunga sekaligus"
          }
        },
        {
          "name": "Model Info",
          "request": {
            "method": "GET",
            "url": "{{ml_url}}/model-info",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Informasi detail model ML"
          }
        },
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "url": "{{ml_url}}/docs",
            "description": "Buka Swagger UI di browser"
          }
        }
      ]
    },
    {
      "name": "Express.js Gateway",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{express_url}}/health",
            "description": "Status Express gateway dan koneksi ke ML service"
          }
        },
        {
          "name": "Predict via Gateway",
          "request": {
            "method": "POST",
            "url": "{{express_url}}/api/predict",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sepal_length\": 5.1,\n  \"sepal_width\": 3.5,\n  \"petal_length\": 1.4,\n  \"petal_width\": 0.2\n}"
            },
            "description": "Prediksi melalui Express gateway (tidak perlu JWT manual, gateway yang handle)"
          }
        },
        {
          "name": "Predict - Iris Versicolor",
          "request": {
            "method": "POST",
            "url": "{{express_url}}/api/predict",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sepal_length\": 7.0,\n  \"sepal_width\": 3.2,\n  \"petal_length\": 4.7,\n  \"petal_width\": 1.4\n}"
            }
          }
        },
        {
          "name": "Batch Predict via Gateway",
          "request": {
            "method": "POST",
            "url": "{{express_url}}/api/predict/batch",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": [\n    { \"sepal_length\": 5.1, \"sepal_width\": 3.5, \"petal_length\": 1.4, \"petal_width\": 0.2 },\n    { \"sepal_length\": 7.0, \"sepal_width\": 3.2, \"petal_length\": 4.7, \"petal_width\": 1.4 },\n    { \"sepal_length\": 6.3, \"sepal_width\": 3.3, \"petal_length\": 6.0, \"petal_width\": 2.5 }\n  ]\n}"
            }
          }
        }
      ]
    }
  ]
}
